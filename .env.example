# Agent URL (รัน Python Agent บน PC ลูกค้า)
# ถ้า dev mode ปล่อยว่างไว้ได้
AGENT_URL="http://localhost:9999"

# Path ของ Express DBF (บน PC ลูกค้า ส่งผ่าน Agent)
DBF_PATH="Z:\\Aulgor"
