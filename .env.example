# .env.local — copy นี้แล้วแก้ค่าให้ตรง

# Database (Supabase หรือ PostgreSQL อื่น)
DATABASE_URL="postgresql://user:password@host:5432/jw_rpa"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
